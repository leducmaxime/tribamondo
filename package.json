  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.17.1",
    "@cloudflare/workers-types": "4.20260103.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "~24.5.2",
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.2",
